<Window
    x:Class="WindowsEdgeLight.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="420"
    Height="340"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    ThemeMode="System">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,20"
            FontSize="20"
            FontWeight="SemiBold"
            Text="⚙️ Settings" />

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Brightness -->
                <Border
                    Margin="0,0,0,12"
                    Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            FontWeight="SemiBold"
                            Text="🔆 Brightness" />
                        <Slider
                            x:Name="BrightnessSlider"
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,8,12,0"
                            Maximum="1.0"
                            Minimum="0.2"
                            SmallChange="0.05"
                            LargeChange="0.15"
                            TickFrequency="0.05"
                            ValueChanged="BrightnessSlider_ValueChanged" />
                        <TextBlock
                            x:Name="BrightnessValueText"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,8,0,0"
                            MinWidth="36"
                            TextAlignment="Right"
                            VerticalAlignment="Center"
                            Text="100%" />
                    </Grid>
                </Border>

                <!-- Color Temperature -->
                <Border
                    Margin="0,0,0,12"
                    Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            FontWeight="SemiBold"
                            Text="🌡️ Color Temperature" />
                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,8,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Slider
                                x:Name="ColorTempSlider"
                                Grid.Row="0"
                                Maximum="1.0"
                                Minimum="0.0"
                                SmallChange="0.05"
                                LargeChange="0.1"
                                TickFrequency="0.05"
                                ValueChanged="ColorTempSlider_ValueChanged" />
                            <Grid Grid.Row="1" Margin="0,2,0,0">
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="❄️ Cool" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    FontSize="11"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="🔥 Warm" />
                            </Grid>
                        </Grid>
                        <TextBlock
                            x:Name="ColorTempValueText"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,8,0,0"
                            MinWidth="36"
                            TextAlignment="Right"
                            VerticalAlignment="Top"
                            Text="50%" />
                    </Grid>
                </Border>

                <!-- Exclude from Capture -->
                <Border
                    Margin="0,0,0,12"
                    Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Text="🖥️ Exclude from Screen Capture" />
                            <TextBlock
                                Margin="0,4,0,0"
                                FontSize="12"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                TextWrapping="Wrap"
                                Text="Hide the edge light from screenshots, Teams, and other screen captures." />
                        </StackPanel>
                        <CheckBox
                            x:Name="ExcludeFromCaptureCheckBox"
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Click="ExcludeFromCapture_Click" />
                    </Grid>
                </Border>

                <!-- Control Window Buttons -->
                <Border
                    Margin="0,0,0,12"
                    Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontWeight="SemiBold"
                            Text="🎛️ Control Bar Buttons" />
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="12"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            Text="Choose which buttons appear in the floating control bar." />
                        <CheckBox
                            x:Name="ShowToggleCheckBox"
                            Margin="0,0,0,8"
                            Content="Show light toggle button"
                            Click="ShowToggle_Click" />
                        <CheckBox
                            x:Name="ShowBrightnessCheckBox"
                            Margin="0,0,0,8"
                            Content="Show brightness buttons"
                            Click="ShowBrightness_Click" />
                        <CheckBox
                            x:Name="ShowColorTempCheckBox"
                            Margin="0,0,0,8"
                            Content="Show color temperature buttons"
                            Click="ShowColorTemp_Click" />
                        <CheckBox
                            x:Name="ShowMonitorControlsCheckBox"
                            Content="Show monitor control buttons"
                            Click="ShowMonitorControls_Click" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
